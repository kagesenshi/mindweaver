apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ name }}
  namespace: argocd
  finalizers:
  - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: 'https://trinodb.github.io/charts'
    chart: trino
    targetRevision: {{ chart_version }}
    helm:
      values: |
        {% if override_image %}
        image:
          tag: "{{ image.split(':')[-1] if ':' in image else 'latest' }}"
          repository: "{{ image.rsplit(':', 1)[0] if ':' in image else image }}"
        {% endif %}
        server:
          workers: {{ replica_count }}
          autoscaling:
            enabled: false
        
        service:
          type: NodePort
        
        {% if catalogs %}
        catalogs:
          {% for catalog in catalogs %}
          {{ catalog.catalog }}: |
            {% for key, value in catalog.properties.items() %}
            {{ key }}={{ value }}
            {% endfor %}
          {% endfor %}
        {% endif %}
        
  destination:
    server: 'https://kubernetes.default.svc'
    namespace: {{ namespace }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
    - CreateNamespace=true
